# ============================================
# Telegram Bot API Configuration
# ============================================
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# ============================================
# YouTube Authentication (Optional but Recommended)
# ============================================
# Prevent "Sign in to confirm you're not a bot" errors
# Choose ONE of the following methods:

# Method 1: Cookie File Path (Recommended)
# Export cookies from your browser using extension like "Get cookies.txt"
# path to the exported cookies.txt file
YOUTUBE_COOKIE_FILE=

# Method 2: Cookie String
# Export cookies as Netscape format string
YOUTUBE_COOKIE=

# Method 3: Browser Cookies (Experimental)
# Options: chrome, firefox, edge, safari, opera
YOUTUBE_BROWSER=
